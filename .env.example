# ─────────────────────────────────────────────────────────────
# .env  —  Parrocchia di Sant'Eligio
# Copia questo file in .env e compila i valori reali.
# NON committare mai .env su git!
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
APP_NAME=Parrocchia di Sant'Eligio
APP_URL=https://santeligio.it
NODE_ENV=production

# ── Backend ───────────────────────────────────────────────────
PORT=3000
JWT_SECRET=cambia_questo_con_una_stringa_random_di_almeno_64_caratteri
JWT_EXPIRES_IN=7d

# Credenziali primo utente admin — usate da `npm run seed`
ADMIN_EMAIL=admin@santeligio.it
ADMIN_PASSWORD=cambia_questa_password_admin

# ── MongoDB ───────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=cambia_questa_password_sicura
MONGO_DB_NAME=santeligio
MONGO_APP_PASSWORD=cambia_questa_password_app
# MONGO_URI è generata automaticamente in docker-compose usando santeligio_app + MONGO_APP_PASSWORD

# ── Uploads ───────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ── Email (per modulo contatti) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=parrocchia@santeligio.it
SMTP_PASS=app_password_qui
MAIL_FROM="Parrocchia Sant'Eligio <parrocchia@santeligio.it>"

# ── Mongo Express (solo dev) ──────────────────────────────────
MONGOEXPRESS_USER=admin
MONGOEXPRESS_PASSWORD=admin_secret
